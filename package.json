{
  "name": "agentic-test-harness-sproj",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "prisma generate",
    "prebuild": "prisma generate",
    "prestart": "prisma generate",
    "postinstall": "prisma generate",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yml down",
    "test:local:setup": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env.test')) fs.copyFileSync('.env.test.example','.env.test');\"",
    "test:local": "npm run test:local:setup && docker compose -f docker-compose.test.yml up -d && npx wait-on tcp:localhost:5434 && npx dotenv-cli -e .env.test -- npx prisma db push && npm run test",
    "test:local:full": "npm run test:local:setup && docker compose -f docker-compose.test.yml up -d && npx wait-on tcp:localhost:5434 && npx dotenv-cli -e .env.test -- npx prisma db push && npm run build && npx start-server-and-test \"npx dotenv-cli -e .env.test -- npm run start\" http://localhost:3000 \"npm run test\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@langchain/openai": "^0.3.6",
    "@prisma/client": "^6.18.0",

    "bcryptjs": "^3.0.2",
    "gpt-tokenizer": "^3.4.0",
    "html2canvas": "^1.4.1",
    "jose": "^6.1.0",
    "jspdf": "^4.0.0",
    "langchain": "^0.3.13",
    "next": "^15.5.9",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "recharts": "^3.6.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.7",
    "dotenv-cli": "^7.4.2",
    "prisma": "^6.18.0",
    "start-server-and-test": "^2.0.3",
    "tailwindcss": "^4",
    "wait-on": "^8.0.1",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  }
}
